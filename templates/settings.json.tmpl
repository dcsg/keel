{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "if [ -f '.keel/config.yaml' ]; then SENTINEL=\"/tmp/keel-$(echo \"$PWD\" | md5sum 2>/dev/null | cut -c1-8 || echo \"$PWD\" | md5 2>/dev/null | cut -c1-8)\"; if [ ! -f \"$SENTINEL\" ]; then touch \"$SENTINEL\"; SOUL=''; ADRS=0; INVS=0; RULES=0; PLANS=0; PRDS=0; [ -f 'docs/soul.md' ] && SOUL=$(head -1 docs/soul.md | sed 's/^#* *//'); ADRS=$(find docs/decisions -maxdepth 1 -name '*.md' 2>/dev/null | wc -l | tr -d ' '); INVS=$(find docs/invariants -maxdepth 1 -name '*.md' 2>/dev/null | wc -l | tr -d ' '); RULES=$(find .claude/rules -maxdepth 1 -name '*.md' 2>/dev/null | wc -l | tr -d ' '); PLANS=$(find docs/product/plans docs/plans -maxdepth 1 -name 'PLAN-*.md' 2>/dev/null | wc -l | tr -d ' '); PRDS=$(find docs/product/prds -maxdepth 1 -name '*.md' 2>/dev/null | wc -l | tr -d ' '); echo \"📋 Keel context available — load with /keel:context before writing code.\"; [ -n \"$SOUL\" ] && echo \"   Project: $SOUL\"; echo \"   Soul: $([ -f docs/soul.md ] && echo 'yes' || echo 'missing')  |  Decisions: $ADRS  |  Invariants: $INVS\"; echo \"   Rules: $RULES packs  |  Plans: $PLANS  |  PRDs: $PRDS\"; fi; fi"
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "echo '⚠️  Context compacting. If a plan is active, update its progress table NOW before context is lost.'"
          }
        ]
      }
    ]
  }
}
