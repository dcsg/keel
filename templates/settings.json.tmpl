{
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "if [ -f '.keel/config.yaml' ]; then ENCODED=$(echo \"$PWD\" | sed 's|/|-|g'); MEMORY=\"$HOME/.claude/projects/${ENCODED}/memory/MEMORY.md\"; if [ -f \"$MEMORY\" ]; then AGE=$(( ($(date +%s) - $(date -r \"$MEMORY\" +%s 2>/dev/null || stat -f %m \"$MEMORY\" 2>/dev/null || echo 0)) / 86400 )); if [ \"$AGE\" -gt 7 ]; then echo \"⚠️  Keel memory is ${AGE} days old. Run /keel:context to refresh.\"; else echo \"📋 Keel project detected — memory loaded (${AGE}d old). Run /keel:context to reload if needed.\"; fi; else echo \"📋 Keel project detected. Run /keel:context to load project context before writing code.\"; fi; fi"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "if [ -f '.keel/config.yaml' ] && [ ! -f 'docs/soul.md' ]; then echo '⚠️  Keel: docs/soul.md not found. Run /keel:init to complete setup.'; fi"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "prompt",
            "prompt": "Review your last response. Check for these signals:\n\n(1) ARCHITECTURE/PRODUCT SIGNALS — did your response contain: a significant technical choice with trade-offs (database selection, architectural pattern, API design, infrastructure decision); a hard constraint that must NEVER be violated (data integrity rule, security boundary, domain purity requirement); or a clearly defined new feature or user need with enough detail to act on?\n\nIf yes, end your next response with ONE of: '💡 This looks like an ADR — run `/keel:adr` to capture it.' OR '💡 This is an invariant — run `/keel:invariant` to capture it.' OR '💡 This looks like a PRD — run `/keel:prd` to capture it.'\n\n(2) DOC GAP SIGNALS — did your response add or change: a new HTTP route or API endpoint; a new environment variable or config key; a new CLI flag or command; a new infrastructure component (Docker service, queue, cron, external dependency); or a breaking change to an existing API or contract?\n\nIf yes, end your next response with a batched summary on its own line: '📄 Doc gap: {specific thing added} may need docs — run `/keel:docs` to review.' Be specific (name the route, env var, or service). Do NOT flag internal refactors, bug fixes, test changes, renames, or formatting.\n\nOnly surface a signal when it is clearly present. Skip for preferences, style choices, and implementation details with no public surface."
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "echo '⚠️  Context compacting. If a plan is active, update its progress table NOW before context is lost.'"
          }
        ]
      }
    ]
  }
}
