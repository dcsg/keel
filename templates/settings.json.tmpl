{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Write|Edit",
        "type": "command",
        "command": "if [ -f '.keel/config.yaml' ]; then SENTINEL=\"/tmp/keel-$(echo \"$PWD\" | md5sum 2>/dev/null | cut -c1-8 || echo \"$PWD\" | md5 2>/dev/null | cut -c1-8)\"; if [ ! -f \"$SENTINEL\" ]; then touch \"$SENTINEL\"; SOUL=''; ADRS=0; INVS=0; RULES=0; PLANS=0; PRDS=0; [ -f 'docs/soul.md' ] && SOUL=$(head -1 docs/soul.md | sed 's/^#* *//'); ADRS=$(ls docs/decisions/*.md 2>/dev/null | wc -l | tr -d ' '); INVS=$(ls docs/invariants/*.md 2>/dev/null | wc -l | tr -d ' '); RULES=$(ls .claude/rules/*.md 2>/dev/null | wc -l | tr -d ' '); PLANS=$(ls docs/product/plans/PLAN-*.md docs/plans/PLAN-*.md 2>/dev/null | wc -l | tr -d ' '); PRDS=$(ls docs/product/prds/*.md 2>/dev/null | wc -l | tr -d ' '); echo \"📋 Keel context available — load with /keel:context before writing code.\"; [ -n \"$SOUL\" ] && echo \"   Project: $SOUL\"; echo \"   Soul: $([ -f docs/soul.md ] && echo 'yes' || echo 'missing')  |  Decisions: $ADRS  |  Invariants: $INVS\"; echo \"   Rules: $RULES packs  |  Plans: $PLANS  |  PRDs: $PRDS\"; fi; fi"
      }
    ],
    "PreCompact": [
      {
        "type": "command",
        "command": "echo '⚠️  Context compacting. If a plan is active, update its progress table NOW before context is lost.'"
      }
    ]
  }
}
